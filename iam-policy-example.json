{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DescribeEc2ForWatchdog",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus"
      ],
      "Resource": "*"
    },
    {
      "Sid": "RebootTargetInstance",
      "Effect": "Allow",
      "Action": "ec2:RebootInstances",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "ec2:ResourceTag/Role": "pixop-target"
        }
      }
    }
  ]
}
